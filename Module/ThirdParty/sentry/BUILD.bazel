filegroup(
    name = "common_srcs",
    srcs = [
        "sentry/src/sentry_alloc.c",
        "sentry/src/sentry_alloc.h",
        "sentry/src/sentry_backend.c",
        "sentry/src/sentry_backend.h",
        "sentry/src/sentry_boot.h",
        "sentry/src/sentry_core.c",
        "sentry/src/sentry_core.h",
        "sentry/src/sentry_database.c",
        "sentry/src/sentry_database.h",
        "sentry/src/sentry_envelope.c",
        "sentry/src/sentry_envelope.h",
        "sentry/src/sentry_info.c",
        "sentry/src/sentry_json.c",
        "sentry/src/sentry_json.h",
        "sentry/src/sentry_logger.c",
        "sentry/src/sentry_logger.h",
        "sentry/src/sentry_options.c",
        "sentry/src/sentry_options.h",
        "sentry/src/sentry_os.c",
        "sentry/src/sentry_os.h",
        "sentry/src/sentry_path.h",
        "sentry/src/sentry_random.c",
        "sentry/src/sentry_random.h",
        "sentry/src/sentry_ratelimiter.c",
        "sentry/src/sentry_ratelimiter.h",
        "sentry/src/sentry_scope.c",
        "sentry/src/sentry_scope.h",
        "sentry/src/sentry_session.c",
        "sentry/src/sentry_session.h",
        "sentry/src/sentry_slice.c",
        "sentry/src/sentry_slice.h",
        "sentry/src/sentry_string.c",
        "sentry/src/sentry_string.h",
        "sentry/src/sentry_symbolizer.h",
        "sentry/src/sentry_sync.c",
        "sentry/src/sentry_sync.h",
        "sentry/src/sentry_transport.c",
        "sentry/src/sentry_transport.h",
        "sentry/src/sentry_utils.c",
        "sentry/src/sentry_utils.h",
        "sentry/src/sentry_uuid.c",
        "sentry/src/sentry_uuid.h",
        "sentry/src/sentry_value.c",
        "sentry/src/sentry_value.h",
        "sentry/src/sentry_tracing.c",
        "sentry/src/sentry_tracing.h",
        "sentry/src/path/sentry_path.c",
        "sentry/src/transports/sentry_disk_transport.c",
        "sentry/src/transports/sentry_disk_transport.h",
        "sentry/src/transports/sentry_function_transport.c",
        "sentry/src/unwinder/sentry_unwinder.c",
    ]
)

filegroup(
    name = "vendor_srcs",
    srcs = [
        "sentry/vendor/jsmn.h",
        "sentry/vendor/mpack.h",
        "sentry/vendor/mpack.c",
    ]
)

filegroup(
    name = "win_srcs",
    srcs = [
        "sentry/src/sentry_windows_dbghelp.c",
		"sentry/src/sentry_windows_dbghelp.h",
		"sentry/src/path/sentry_path_windows.c",
		"sentry/src/symbolizer/sentry_symbolizer_windows.c",
        "sentry/src/modulefinder/sentry_modulefinder_windows.c",
        "sentry/src/unwinder/sentry_unwinder_dbghelp.c",
    ]
)

filegroup(
    name = "backend_srcs",
    srcs = [
        "sentry/src/backends/sentry_backend_inproc.c",
    ]
)

filegroup(
    name = "transport_srcs",
    srcs = [
        "sentry/src/transports/sentry_transport_winhttp.c",
    ]
)

cc_library(
    name = "sentry",
    srcs = [
        ":common_srcs",
        ":vendor_srcs",
        ":win_srcs",
        ":backend_srcs",
        ":transport_srcs",
    ],
    hdrs = glob(["sentry/include/**/*.h"]),
    defines = [
        "SENTRY_BUILD_STATIC=1",
        "SENTRY_WITH_UNWINDER_DBGHELP=1",
    ],
    linkopts = [
        "winhttp.lib",
    ],
    includes = ["sentry/include", "sentry/src"],
    visibility = ["//visibility:public"],
)
